<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Code Review Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0c0d10;--surface:#14161b;--surface2:#1a1c22;--border:#262830;--text:#e2e4e9;--dim:#6b7084;--accent:#635bff;--accent2:#8b83ff;--accent-dim:#635bff18;--red:#ef4444;--orange:#f59e0b;--green:#22c55e;--deep:#c084fc;--red-bg:#ef444410;--orange-bg:#f59e0b10;--green-bg:#22c55e10;--deep-bg:#c084fc10;--mono:'JetBrains Mono',monospace;--sans:'DM Sans',system-ui,sans-serif;--radius:10px}
*{margin:0;padding:0;box-sizing:border-box}body{background:var(--bg);color:var(--text);font-family:var(--sans);height:100vh;overflow:hidden}
.app{display:grid;grid-template-columns:1fr 320px;grid-template-rows:52px 1fr;height:100vh}
@media(max-width:960px){.app{grid-template-columns:1fr;grid-template-rows:52px 1fr}.chat-panel{display:none}}
.header{grid-column:1/-1;display:flex;align-items:center;gap:10px;padding:0 16px;border-bottom:1px solid var(--border);background:var(--surface)}
.header .logo{width:30px;height:30px;background:var(--accent);border-radius:7px;display:grid;place-items:center;font-family:var(--mono);font-weight:700;font-size:14px;color:#fff}
.header h1{font-size:15px;font-weight:700}.header .ver{font-size:9px;color:var(--accent);background:var(--accent-dim);padding:2px 6px;border-radius:4px;font-weight:600}
.header .spacer{flex:1}
.header select{background:var(--surface2);border:1px solid var(--border);color:var(--text);font-family:var(--sans);font-size:11px;padding:5px 8px;border-radius:5px;cursor:pointer}
.header label{font-size:11px;color:var(--dim);display:flex;align-items:center;gap:4px}
.main{display:grid;grid-template-columns:1fr 1fr;gap:0;overflow:hidden}
@media(max-width:700px){.main{grid-template-columns:1fr;grid-template-rows:1fr 1fr}}
.panel{display:flex;flex-direction:column;overflow:hidden;border-right:1px solid var(--border)}
.panel:last-child{border-right:none}
.panel-head{padding:10px 14px;border-bottom:1px solid var(--border);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--dim);display:flex;justify-content:space-between;align-items:center;background:var(--surface);flex-shrink:0}
.panel-body{flex:1;overflow-y:auto;padding:12px 14px}
.mode-bar{display:flex;gap:0;border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:10px}
.mode-btn{flex:1;padding:7px;text-align:center;font-size:11px;font-weight:600;cursor:pointer;background:var(--surface2);color:var(--dim);border:none;transition:all .15s}.mode-btn.active{background:var(--accent);color:#fff}.mode-btn:hover:not(.active){color:var(--text)}
.form-row{display:flex;gap:6px;margin-bottom:8px}
.form-row select,.form-row input{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;padding:7px 10px;outline:none}
.form-row select{width:auto;min-width:100px}.form-row input{flex:1}
.form-row select:focus,.form-row input:focus,textarea:focus{border-color:var(--accent)}
textarea{width:100%;min-height:180px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:11px;line-height:1.6;padding:12px;resize:vertical;outline:none;tab-size:4;flex:1}
.btn-row{display:flex;gap:6px;margin-top:8px}
button{padding:8px 14px;font-family:var(--sans);font-size:12px;font-weight:600;border:none;border-radius:7px;cursor:pointer;transition:all .15s}
button:hover{opacity:.85}button:disabled{opacity:.35;cursor:not-allowed}
.btn-primary{background:var(--accent);color:#fff;flex:1}.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text)}.btn-green{background:var(--green);color:#000}.btn-sm{padding:5px 10px;font-size:10px}
.tabs{display:flex;gap:0;margin-bottom:10px}.tab-btn{flex:1;padding:7px;text-align:center;font-size:11px;font-weight:600;cursor:pointer;background:var(--surface2);color:var(--dim);border:none;border-bottom:2px solid transparent}.tab-btn.active{color:var(--accent);border-bottom-color:var(--accent)}
.upload-area{border:2px dashed var(--border);border-radius:7px;padding:20px;text-align:center;color:var(--dim);font-size:11px;cursor:pointer;margin-bottom:8px}.upload-area:hover,.upload-area.dragover{border-color:var(--accent)}.upload-area input{display:none}
.file-tag{display:flex;align-items:center;justify-content:space-between;background:var(--surface2);border-radius:5px;padding:6px 10px;font-size:11px;margin-bottom:8px}.file-tag .name{font-family:var(--mono);color:var(--accent)}.file-tag .x{color:var(--red);cursor:pointer}

/* ---- NEW: token counter + preflight banner ---- */
.token-counter{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;border-radius:6px;font-size:10px;font-family:var(--mono);margin:6px 0 8px;background:var(--surface2);border:1px solid var(--border)}
.token-counter.green{color:var(--green);border-color:var(--green)}
.token-counter.amber{color:var(--orange);border-color:var(--orange);background:var(--orange-bg)}
.token-counter.red{color:var(--red);border-color:var(--red);background:var(--red-bg)}
.preflight-banner{padding:10px 12px;border-radius:7px;margin-bottom:8px;font-size:11px;border:1px solid var(--red);color:var(--red);background:var(--red-bg);display:none}
.preflight-banner.shown{display:block}
.preflight-banner .title{font-weight:700;margin-bottom:2px}

.empty{color:var(--dim);font-size:12px;text-align:center;padding:50px 0;line-height:1.7}
.summary{background:var(--surface2);border-radius:7px;padding:10px 14px;margin-bottom:10px;font-size:12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px}
.tags{display:flex;gap:4px;flex-wrap:wrap}
.tag{font-family:var(--mono);font-size:9px;font-weight:600;padding:2px 6px;border-radius:4px}
.tag-fast{background:var(--accent-dim);color:var(--accent)}.tag-deep{background:var(--deep-bg);color:var(--deep)}.tag-model{background:var(--green-bg);color:var(--green)}.tag-tok{background:var(--orange-bg);color:var(--orange)}.tag-mode{background:#ff579920;color:#ff5799}.tag-team{background:#06b6d420;color:#06b6d4}.tag-route{background:#635bff30;color:var(--accent2)}
.issue{border:1px solid var(--border);border-radius:7px;padding:12px;margin-bottom:8px;font-size:12px}
.issue.high{border-left:3px solid var(--red);background:var(--red-bg)}.issue.medium{border-left:3px solid var(--orange);background:var(--orange-bg)}.issue.low{border-left:3px solid var(--green);background:var(--green-bg)}
.issue-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}.sev{font-size:9px;font-weight:700;text-transform:uppercase;padding:2px 5px;border-radius:3px}.high .sev{color:var(--red)}.medium .sev{color:var(--orange)}.low .sev{color:var(--green)}
.loc{font-family:var(--mono);font-size:10px;color:var(--dim)}.issue-title{font-weight:600;font-size:12px;margin-bottom:3px}.issue-body{font-size:11px;color:var(--dim);line-height:1.5;margin-bottom:6px}
.code-block{background:var(--bg);border-radius:5px;padding:8px 10px;font-family:var(--mono);font-size:10px;line-height:1.5;white-space:pre-wrap;overflow-x:auto;margin-bottom:5px}
.rule{font-size:10px;color:var(--accent);font-weight:500}
.issue-actions{display:flex;gap:6px;margin-top:6px}
.btn-regen{background:transparent;border:1px solid var(--accent);color:var(--accent);padding:4px 10px;font-size:10px;font-weight:600;border-radius:5px;cursor:pointer}
.btn-regen:hover{background:var(--accent-dim)}
.alt-fix-box{background:var(--accent-dim);border:1px solid var(--accent);border-radius:6px;padding:8px 10px;margin-top:6px;font-size:11px}
.alt-fix-box .alt-head{font-weight:700;color:var(--accent2);margin-bottom:4px}
.alt-fix-box .alt-why{color:var(--dim);margin-top:4px;font-size:10px;font-style:italic}

.suggest{background:var(--deep-bg);border:1px solid var(--deep);border-radius:7px;padding:10px 14px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;gap:8px;font-size:11px}
.suggest .txt{color:var(--deep);flex:1}.suggest .reasons{font-size:9px;color:var(--dim);margin-top:2px}
.preview-box{background:var(--surface2);border:1px solid var(--accent);border-radius:7px;padding:12px;margin-bottom:10px}.preview-box h4{font-size:11px;color:var(--accent);margin-bottom:6px}
.preview-code{background:var(--bg);border-radius:5px;padding:10px;font-family:var(--mono);font-size:10px;line-height:1.5;white-space:pre-wrap;max-height:250px;overflow-y:auto;margin-bottom:8px}
.changes-list{font-size:10px;color:var(--dim);line-height:1.5;margin-bottom:8px}
.deep-stats{background:var(--deep-bg);border-radius:7px;padding:8px 12px;margin-bottom:8px;font-size:10px;color:var(--deep);font-family:var(--mono)}
.security-note{background:var(--red-bg);border:1px solid var(--red);border-radius:7px;padding:8px 12px;margin-bottom:8px;font-size:11px;color:var(--red)}
.partial-banner{background:var(--orange-bg);border:1px solid var(--orange);border-radius:7px;padding:8px 12px;margin-bottom:8px;font-size:11px;color:var(--orange)}

/* ---- NEW: function selector (2-pass update) ---- */
.fn-selector{background:var(--surface2);border:1px solid var(--accent);border-radius:7px;padding:12px;margin-bottom:10px}
.fn-selector h4{font-size:11px;color:var(--accent);margin-bottom:8px}
.fn-selector .fn-help{font-size:10px;color:var(--dim);margin-bottom:8px;line-height:1.5}
.fn-selector .fn-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px}
.fn-selector label{display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--bg);border-radius:5px;font-family:var(--mono);font-size:11px;cursor:pointer}
.fn-selector label:hover{background:var(--surface)}
.fn-selector input[type=checkbox]{accent-color:var(--accent);cursor:pointer}

.dbg{margin-top:8px;border:1px solid var(--border);border-radius:7px;overflow:hidden}.dbg-toggle{width:100%;background:var(--surface2);border:none;color:var(--dim);font-family:var(--mono);font-size:10px;padding:7px 10px;cursor:pointer;text-align:left;display:flex;justify-content:space-between}.dbg-toggle:hover{color:var(--text)}.dbg-body{padding:10px;font-family:var(--mono);font-size:10px;line-height:1.5;display:none;max-height:200px;overflow-y:auto}.dbg-body.open{display:block}
.dtag{display:inline-block;padding:1px 4px;border-radius:3px;font-size:8px;font-weight:600;margin:0 2px 2px 0}.dtag-c{background:#635bff18;color:var(--accent)}.dtag-s{background:#22c55e18;color:var(--green)}
.violations{padding:8px 12px;background:var(--surface2);border-radius:7px;font-size:10px;color:var(--dim);margin-top:8px}
.loading{text-align:center;padding:40px 0;color:var(--dim)}.spinner-lg{display:inline-block;width:24px;height:24px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;margin-bottom:8px}
.timer{font-family:var(--mono);font-size:16px;color:var(--text);margin:4px 0}.loading p{font-size:11px}@keyframes spin{to{transform:rotate(360deg)}}
.spinner-sm{display:inline-block;width:12px;height:12px;border:2px solid var(--dim);border-top-color:var(--accent);border-radius:50%;animation:spin .5s linear infinite;margin-right:4px;vertical-align:middle}
.no-issues{text-align:center;padding:24px 0;color:var(--green);font-size:13px}.no-issues .icon{font-size:24px;margin-bottom:4px}
.chat-panel{border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;background:var(--surface)}
.chat-head{padding:10px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--dim);flex-shrink:0}
.chat-msgs{flex:1;overflow-y:auto;padding:10px 12px}.chat-msg{margin-bottom:8px;font-size:11px;line-height:1.4}
.chat-msg.user{text-align:right}.chat-msg.user .bubble{background:var(--accent-dim);color:var(--accent2);display:inline-block;padding:6px 10px;border-radius:7px 7px 2px 7px;max-width:85%;text-align:left}
.chat-msg.assistant .bubble{background:var(--surface2);color:var(--text);display:inline-block;padding:6px 10px;border-radius:7px 7px 7px 2px;max-width:85%;text-align:left}
.chat-msg .time{font-size:8px;color:var(--dim);margin-top:1px}
.chat-input{display:flex;gap:6px;padding:10px 12px;border-top:1px solid var(--border);flex-shrink:0}.chat-input input{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:11px;padding:7px 10px;outline:none}
.sug-item{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--surface2);border-radius:5px;margin-bottom:5px;font-size:11px}.sug-item .stitle{font-weight:600}.sug-item .smeta{font-size:9px;color:var(--dim)}.sug-item .actions{display:flex;gap:4px}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="logo">CR</div><h1>Code Review Assistant</h1><span class="ver">v2.0 · minimax</span>
    <div class="spacer"></div>
    <label>Team: <select id="team-select" onchange="onTeamChange()"></select></label>
    <label>Lang: <select id="header-lang">
      <option value="auto">Auto-detect</option>
      <option value="java">Java</option><option value="typescript">TypeScript</option><option value="python">Python</option>
      <option value="go">Go</option><option value="rust">Rust</option><option value="csharp">C#</option><option value="cpp">C++</option>
      <option value="javascript">JavaScript</option><option value="kotlin">Kotlin</option><option value="ruby">Ruby</option>
      <option value="php">PHP</option><option value="swift">Swift</option>
    </select></label>
  </div>
  <div class="main">
    <div class="panel">
      <div class="panel-head"><span>Input</span><span id="session-tag" style="font-size:9px;color:var(--accent)"></span></div>
      <div class="panel-body" style="display:flex;flex-direction:column">
        <div class="mode-bar">
          <button class="mode-btn active" onclick="setMode('no')">Review Only</button>
          <button class="mode-btn" onclick="setMode('yes')">Suggest Code</button>
          <button class="mode-btn" onclick="setMode('update')">Auto Update</button>
        </div>
        <div class="tabs">
          <button class="tab-btn active" onclick="switchInput('paste')">Paste</button>
          <button class="tab-btn" onclick="switchInput('upload')">Upload</button>
          <button class="tab-btn" onclick="switchInput('suggest')">Rules</button>
        </div>
        <div id="input-paste">
          <div class="form-row"><input type="text" id="question" value="What is wrong with this code?" placeholder="Your question..."></div>
          <textarea id="code" placeholder="Paste code here..." spellcheck="false" oninput="updateTokenCounter()">@RestController
public class OrderController {
    @Autowired
    private UserService userService;

    @PostMapping("/orders")
    public ResponseEntity&lt;Order&gt; createOrder(Long userId, Cart cart) {
        User user = userService.findById(userId);
        Order order = new Order();
        order.setUser(user);
        orderRepo.save(order);
        return ResponseEntity.ok(order);
    }
}</textarea>
          <!-- NEW: live token counter + preflight banner -->
          <div class="token-counter" id="token-counter">
            <span id="tc-estimate">~0 tokens</span>
            <span id="tc-verdict">fits in single call</span>
          </div>
          <div class="preflight-banner" id="preflight-banner">
            <div class="title">Input too large</div>
            <div id="preflight-msg"></div>
          </div>
          <div class="btn-row">
            <button class="btn-primary" id="btn-go" onclick="submitReview()">Review Code</button>
            <label style="display:flex;align-items:center;gap:3px;font-size:10px;color:var(--dim);cursor:pointer;white-space:nowrap">
              <input type="checkbox" id="show-reasoning"> Reasoning
            </label>
          </div>
        </div>
        <div id="input-upload" style="display:none">
          <div class="upload-area" id="drop-zone" onclick="document.getElementById('file-in').click()">
            Drop a file here or click to browse<input type="file" id="file-in" accept=".java,.ts,.tsx,.js,.jsx,.py,.go,.rs,.cs,.cpp,.rb,.php,.swift,.kt" onchange="pickFile(this)">
          </div>
          <div class="file-tag" id="file-tag" style="display:none"><span>File: <span class="name" id="fname"></span></span><span class="x" onclick="clearFile()">X</span></div>
          <div class="btn-row"><button class="btn-primary" onclick="submitFile()">Review File</button></div>
        </div>
        <div id="input-suggest" style="display:none">
          <div style="font-size:11px;color:var(--dim);margin-bottom:8px">Custom rules the AI follows during reviews. Rules are team-scoped.</div>
          <div class="form-row"><input type="text" id="sug-title" placeholder="Rule title"></div>
          <div class="form-row"><input type="text" id="sug-rule" placeholder="Rule description"></div>
          <div class="form-row">
            <select id="sug-lang"><option value="all">All languages</option><option value="java">Java</option><option value="typescript">TypeScript</option><option value="python">Python</option><option value="go">Go</option><option value="rust">Rust</option><option value="csharp">C#</option><option value="cpp">C++</option><option value="javascript">JavaScript</option><option value="kotlin">Kotlin</option><option value="ruby">Ruby</option><option value="php">PHP</option><option value="swift">Swift</option></select>
            <select id="sug-team"><option value="all">All teams</option></select>
          </div>
          <div class="form-row"><input type="text" id="sug-bad" placeholder="Bad example (optional)"></div>
          <div class="form-row"><input type="text" id="sug-good" placeholder="Good example (optional)"></div>
          <div class="btn-row"><button class="btn-primary" onclick="addRule()">Add Rule</button></div>
          <div id="rules-list" style="margin-top:10px"></div>
        </div>
      </div>
    </div>
    <div class="panel" style="border-right:1px solid var(--border)">
      <div class="panel-head">Results</div>
      <div class="panel-body" id="results"><div class="empty">Submit code to review.<br>Select your team and mode above.</div></div>
    </div>
  </div>
  <div class="chat-panel">
    <div class="chat-head">Chat History</div>
    <div class="chat-msgs" id="chat-msgs"></div>
    <div class="chat-input"><input type="text" id="chat-in" placeholder="Follow-up..." onkeydown="if(event.key==='Enter')sendChat()"><button class="btn-primary btn-sm" onclick="sendChat()">Send</button></div>
  </div>
</div>
<script>
let mode='no',selectedFile=null,timerInt=null,sessionId='',lastReview=null,lastCode='',lastLang='',lastTeam='';

// ---- Token counter thresholds (matches server-side token_router.py) ----
// Client-side char/4 is a rough estimate; server is authoritative.
const LIMIT_SINGLE_CALL  = 5_000;   // green up to here
const LIMIT_LARGE        = 50_000;  // amber above here
const LIMIT_HARD_REJECT  = 60_000;  // red, disable submit

// ---- Teams bootstrap ----
async function loadTeams(){
  try{
    const res=await fetch('/teams');const d=await res.json();
    const sel=document.getElementById('team-select');
    const sugSel=document.getElementById('sug-team');
    sel.innerHTML='';sugSel.innerHTML='<option value="all">All teams</option>';
    for(const t of d.teams){
      sel.innerHTML+=`<option value="${t.id}">${t.name}</option>`;
      sugSel.innerHTML+=`<option value="${t.id}">${t.name}</option>`;
    }
  }catch(e){console.error('Failed to load teams:',e)}
}
loadTeams();

function onTeamChange(){lastTeam=document.getElementById('team-select').value}
function setMode(m){mode=m;document.querySelectorAll('.mode-btn').forEach((b,i)=>{b.classList.toggle('active',['no','yes','update'][i]===m)})}
function switchInput(t){['paste','upload','suggest'].forEach(x=>{document.getElementById('input-'+x).style.display=x===t?'':'none'});document.querySelectorAll('.tab-btn').forEach((b,i)=>{b.classList.toggle('active',['paste','upload','suggest'][i]===t)});if(t==='suggest')loadRules()}
function pickFile(el){
  if(el.files.length>0){
    selectedFile=el.files[0];
    document.getElementById('fname').textContent=selectedFile.name;
    document.getElementById('file-tag').style.display='';
    // Read file and update token counter immediately (plan: token count on file load)
    const reader=new FileReader();
    reader.onload=function(ev){
      document.getElementById('code').value=ev.target.result;
      updateTokenCounter();
    };
    reader.readAsText(selectedFile);
  }
}
function clearFile(){selectedFile=null;document.getElementById('file-in').value='';document.getElementById('file-tag').style.display='none'}
const dz=document.getElementById('drop-zone');dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('dragover')});dz.addEventListener('dragleave',()=>dz.classList.remove('dragover'));dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('dragover');if(e.dataTransfer.files.length){document.getElementById('file-in').files=e.dataTransfer.files;pickFile(document.getElementById('file-in'))}});

// ---- NEW: Live token counter + preflight ----
function estimateTokens(text){ return Math.ceil((text||'').length / 4); }

function updateTokenCounter(){
  const code=document.getElementById('code').value;
  const tokens=estimateTokens(code);
  const lines=code.split('\n').length;
  const tc=document.getElementById('token-counter');
  const est=document.getElementById('tc-estimate');
  const verdict=document.getElementById('tc-verdict');
  const banner=document.getElementById('preflight-banner');
  const msg=document.getElementById('preflight-msg');
  const btn=document.getElementById('btn-go');

  est.textContent=`~${tokens.toLocaleString()} tokens · ${lines.toLocaleString()} lines`;

  tc.classList.remove('green','amber','red');
  if(tokens < LIMIT_SINGLE_CALL){
    tc.classList.add('green');
    verdict.textContent='fits in single call';
    banner.classList.remove('shown');
    btn.disabled=false;
  } else if(tokens < LIMIT_LARGE){
    tc.classList.add('green');
    verdict.textContent='fits (single call, any mode)';
    banner.classList.remove('shown');
    btn.disabled=false;
  } else if(tokens < LIMIT_HARD_REJECT){
    tc.classList.add('amber');
    verdict.textContent=(mode==='update')?'large · will use 2-pass flow':'large · review-only recommended';
    banner.classList.remove('shown');
    btn.disabled=false;
  } else {
    tc.classList.add('red');
    verdict.textContent='too large';
    banner.classList.add('shown');
    msg.textContent=`~${tokens.toLocaleString()} tokens (${lines.toLocaleString()} lines). Max is ~${LIMIT_HARD_REJECT.toLocaleString()} tokens (~6,000 lines). Paste a single class or file.`;
    btn.disabled=true;
  }
}
// Run once on load to set initial state
document.addEventListener('DOMContentLoaded',updateTokenCounter);
updateTokenCounter();

function startLoad(msg){const r=document.getElementById('results');let s=0;r.innerHTML=`<div class="loading"><div class="spinner-lg"></div><div class="timer">0s</div><p>${msg}</p></div>`;timerInt=setInterval(()=>{s++;const t=r.querySelector('.timer');if(t)t.textContent=s+'s'},1000)}
function stopLoad(){clearInterval(timerInt)}
function addChat(role,text){const box=document.getElementById('chat-msgs');const d=document.createElement('div');d.className='chat-msg '+role;const now=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});d.innerHTML=`<div class="bubble">${esc(text).substring(0,300)}</div><div class="time">${now}</div>`;box.appendChild(d);box.scrollTop=box.scrollHeight}

async function submitReview(){
  const btn=document.getElementById('btn-go');btn.disabled=true;btn.innerHTML='<span class="spinner-sm"></span>Working...';
  lastCode=document.getElementById('code').value;lastLang=document.getElementById('header-lang').value;lastTeam=document.getElementById('team-select').value;
  startLoad(`Reviewing with ${lastTeam} rules...`);
  addChat('user',document.getElementById('question').value);
  try{
    const body={language:lastLang,code:lastCode,question:document.getElementById('question').value,mode,team:lastTeam,session_id:sessionId,show_reasoning:document.getElementById('show-reasoning').checked};
    const res=await fetch('/review',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    stopLoad();
    if(!res.ok){
      let body=null;try{body=await res.json()}catch{}
      throw new Error(body?.detail || ('HTTP '+res.status));
    }
    const d=await res.json();
    if(d.session_id)sessionId=d.session_id;document.getElementById('session-tag').textContent=sessionId?'#'+sessionId:'';
    lastReview=d;renderResults(d);addChat('assistant',d.summary);
  }catch(e){
    stopLoad();
    document.getElementById('results').innerHTML=`<div style="color:var(--red);padding:16px;font-size:12px">${esc(e.message)}</div>`;
    addChat('assistant','Error: '+e.message);
  }finally{
    btn.disabled=false;btn.textContent='Review Code';updateTokenCounter();
  }
}

async function submitFile(){
  if(!selectedFile)return alert('Select a file');
  lastLang=document.getElementById('header-lang').value;lastTeam=document.getElementById('team-select').value;
  startLoad('Reviewing '+selectedFile.name+'...');
  try{
    const fd=new FormData();
    fd.append('file',selectedFile);fd.append('language',lastLang);fd.append('question','What is wrong?');fd.append('mode',mode);fd.append('team',lastTeam);
    const res=await fetch('/review-file',{method:'POST',body:fd});
    stopLoad();
    if(!res.ok)throw new Error('HTTP '+res.status);
    const d=await res.json();
    lastReview=d;lastCode=await selectedFile.text();
    if(d.session_id)sessionId=d.session_id;
    renderResults(d);addChat('assistant',d.summary);
  }catch(e){
    stopLoad();
    document.getElementById('results').innerHTML=`<div style="color:var(--red);padding:16px;font-size:12px">${esc(e.message)}</div>`;
  }
}

async function approveUpdate(){
  if(!sessionId)return;
  try{
    const res=await fetch('/apply-preview?session_id='+sessionId,{method:'POST'});
    const d=await res.json();
    if(d.status==='applied'){addChat('assistant','Applied.');alert('Updated code ready. Copy from preview.')}
  }catch(e){alert(e.message)}
}

async function sendChat(){
  const inp=document.getElementById('chat-in');const msg=inp.value.trim();if(!msg)return;inp.value='';
  addChat('user',msg);
  if(lastCode){
    try{
      const res=await fetch('/review',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({language:lastLang,code:lastCode,question:msg,mode,team:lastTeam,session_id:sessionId})});
      const d=await res.json();renderResults(d);addChat('assistant',d.summary);
    }catch(e){addChat('assistant','Error: '+e.message)}
  } else {
    addChat('assistant','Paste code first.');
  }
}

// ---- NEW: Pass 2 of 2-pass update flow ----
async function submitSelectedFunctions(){
  const checks=document.querySelectorAll('#fn-selector-list input[type=checkbox]:checked');
  const fnNames=Array.from(checks).map(c=>c.value);
  if(!fnNames.length)return alert('Select at least one function to fix.');
  startLoad(`Fixing ${fnNames.length} function(s)...`);
  try{
    const res=await fetch('/review-functions',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({session_id:sessionId,function_names:fnNames})});
    stopLoad();
    if(!res.ok){
      let body=null;try{body=await res.json()}catch{}
      throw new Error(body?.detail || ('HTTP '+res.status));
    }
    const d=await res.json();lastReview=d;renderResults(d);addChat('assistant',`Fix pass: ${d.summary}`);
  }catch(e){
    stopLoad();
    document.getElementById('results').innerHTML=`<div style="color:var(--red);padding:16px;font-size:12px">${esc(e.message)}</div>`;
  }
}

// ---- NEW: "Try different fix" regenerate ----
async function regenerateFix(issueId,btnEl){
  const orig=btnEl.textContent;btnEl.disabled=true;btnEl.innerHTML='<span class="spinner-sm"></span>…';
  try{
    const res=await fetch('/regenerate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({session_id:sessionId,issue_id:issueId})});
    if(!res.ok){
      let body=null;try{body=await res.json()}catch{}
      throw new Error(body?.detail || ('HTTP '+res.status));
    }
    const d=await res.json();
    if(d.status!=='ok'){throw new Error(d.error||'regenerate failed')}
    // Render the alternative in-place under the issue card
    const issueCard=btnEl.closest('.issue');
    // Remove old alt boxes so we show only the newest
    issueCard.querySelectorAll('.alt-fix-box').forEach(n=>n.remove());
    const box=document.createElement('div');
    box.className='alt-fix-box';
    box.innerHTML=`<div class="alt-head">Alternative #${d.attempt_number} · ${esc(d.approach_name||'alternative')}</div><div class="code-block">${esc(d.alternative_fix||'')}</div><div class="alt-why">${esc(d.why_valid||'')}</div>`;
    issueCard.appendChild(box);
  }catch(e){
    alert('Regenerate failed: '+e.message);
  }finally{
    btnEl.disabled=false;btnEl.textContent=orig;
  }
}

function renderResults(d){
  const el=document.getElementById('results');let h='';const ti=d.token_info||{},ci=d.chunking_info||{};
  h+=`<div class="summary"><span>${esc(d.summary)}</span><div class="tags"><span class="tag tag-fast">${d.pass_used}</span>${d.route?`<span class="tag tag-route">${esc(d.route)}</span>`:''}${d.team?`<span class="tag tag-team">${esc(d.team)}</span>`:''}<span class="tag tag-mode">${d.mode||'no'}</span>${ti.model?`<span class="tag tag-model">${esc(ti.model)}</span>`:''}${ti.input_tokens?`<span class="tag tag-tok">in:${ti.input_tokens}</span>`:''}</div></div>`;
  if(d.language_detection&&d.language_detection.confidence)h+=`<div style="font-size:10px;color:var(--dim);margin-bottom:8px">Detected: ${d.language_detection.language} (${d.language_detection.confidence})</div>`;

  // Partial / truncated warning
  if(d.truncated){h+=`<div class="partial-banner">⚠ Partial review — response was truncated mid-JSON. Issues below are valid but the list may be incomplete. Try review-only mode, or paste a smaller section.</div>`}

  // Auto-trigger suggestion (security/suspicious)
  if(d.deep_review_suggestion&&d.deep_review_suggestion.suggest){
    const rs=d.deep_review_suggestion.reasons.map(r=>esc(r)).join(', ');
    h+=`<div class="suggest"><div><div class="txt">Deep review recommended</div><div class="reasons">${rs}</div></div></div>`
  }

  // Deep review stats (if this was a critique pass)
  if(d.deep_review_stats){const s=d.deep_review_stats;h+=`<div class="deep-stats">${s.confirmed||0} confirmed, ${s.corrected||0} corrected, ${s.removed||0} removed, ${s.new_found||0} new</div>`}
  if(d.security_notes)h+=`<div class="security-note">${esc(d.security_notes)}</div>`;
  if(d.reasoning)h+=`<div class="dbg"><button class="dbg-toggle" onclick="this.nextElementSibling.classList.toggle('open')">AI Reasoning</button><div class="dbg-body">${esc(d.reasoning)}</div></div>`;
  if(ti.error)h+=`<div style="background:var(--red-bg);border:1px solid var(--red);border-radius:7px;padding:10px;margin-bottom:8px;font-size:11px;color:var(--red)">${esc(ti.error)}</div>`;

  // NEW: function selector for Pass 2 of update flow
  if(d.pass_used==='single-pass1' && d.affected_functions && d.affected_functions.length){
    h+=`<div class="fn-selector" id="fn-selector"><h4>Pass 2: select functions to fix</h4>`;
    h+=`<div class="fn-help">Pass 1 found issues in the functions below. Check the ones you want the model to rewrite in a targeted second pass, then click Fix Selected. The rest of the file stays untouched.</div>`;
    h+=`<div class="fn-list" id="fn-selector-list">`;
    for(const fn of d.affected_functions){
      h+=`<label><input type="checkbox" value="${esc(fn)}" checked> ${esc(fn)}()</label>`;
    }
    h+=`</div>`;
    h+=`<div class="btn-row"><button class="btn-primary" onclick="submitSelectedFunctions()">Fix Selected</button></div>`;
    h+=`</div>`;
  }

  // Updated/suggested code block
  if(d.updated_code||d.suggested_code){
    const code=d.updated_code||d.suggested_code;
    const label=d.updated_code?'Updated Code':'Suggested Code';
    let cl='';
    if(d.changes&&d.changes.length){
      cl='<div class="changes-list"><strong>Changes:</strong><br>'+d.changes.map(c=>esc((c.line||'')+': '+(c.what||'')+' -- '+(c.why||''))).join('<br>')+'</div>';
    }
    h+=`<div class="preview-box"><h4>${label}${d.preview?' (pending approval)':''}</h4>${cl}<div class="preview-code">${esc(code)}</div>${d.preview?'<div class="btn-row"><button class="btn-green btn-sm" onclick="approveUpdate()">Approve</button><button class="btn-outline btn-sm" onclick="this.closest(\'.preview-box\').remove()">Dismiss</button></div>':''}<button class="btn-outline btn-sm" onclick="navigator.clipboard.writeText(decodeURIComponent('${encodeURIComponent(code)}'));this.textContent='Copied!'">Copy</button></div>`;
  }

  // Issues list (each with a "Try different fix" regen button)
  if(!d.issues||d.issues.length===0){
    h+=`<div class="no-issues"><div class="icon">OK</div>No issues found</div>`;
  } else {
    for(const i of d.issues){
      h+=`<div class="issue ${i.severity}" data-issue-id="${i.id}">`+
        `<div class="issue-top"><span class="sev">${i.severity}</span><span class="loc">${esc(i.location)}</span></div>`+
        `<div class="issue-title">${esc(i.problem)}</div>`+
        `<div class="issue-body">${esc(i.explanation)}</div>`+
        (i.fix?`<div class="code-block">${esc(i.fix)}</div>`:'')+
        `<div class="rule">${esc(i.rule_violated)}</div>`+
        `<div class="issue-actions"><button class="btn-regen" onclick="regenerateFix(${i.id},this)">↻ Try different fix</button></div>`+
        `</div>`;
    }
  }

  if(d.style_violations&&d.style_violations.length)h+=`<div class="violations"><strong style="color:var(--text)">Violations:</strong> ${d.style_violations.map(s=>esc(s)).join(' | ')}</div>`;
  if(d.rag_context){
    const rc=d.rag_context;
    let srcs='',cats='';
    if(rc.sources)for(const s of rc.sources)srcs+=`<span class="dtag dtag-s">${s.id}</span>`;
    if(rc.detected_categories)for(const[k,v]of Object.entries(rc.detected_categories))cats+=`<span class="dtag dtag-c">${k}:${(v*100).toFixed(0)}%</span>`;
    h+=`<div class="dbg"><button class="dbg-toggle" onclick="this.nextElementSibling.classList.toggle('open')"><span>RAG Debug</span><span>${rc.retrieved_tokens||0}tok</span></button><div class="dbg-body">${cats}<br>${srcs}</div></div>`;
  }
  el.innerHTML=h;
}

async function loadRules(){
  const team=document.getElementById('team-select').value||'all';
  try{
    const res=await fetch(`/suggestions?team=${team}`);const d=await res.json();
    const list=document.getElementById('rules-list');
    if(!d.suggestions||!d.suggestions.length){list.innerHTML='<div style="color:var(--dim);font-size:11px">No custom rules yet.</div>';return}
    list.innerHTML=d.suggestions.map(s=>`<div class="sug-item"><div><div class="stitle">${esc(s.title)}</div><div class="smeta">${s.language||'all'} | ${s.team||'all'}</div></div><div class="actions"><button class="btn-outline btn-sm" onclick="deleteRule('${s.id}')">Del</button></div></div>`).join('');
  }catch(e){console.error(e)}
}

async function addRule(){
  const t=document.getElementById('sug-title').value.trim();const r=document.getElementById('sug-rule').value.trim();if(!t||!r)return alert('Title and rule required');
  const team=document.getElementById('sug-team').value;
  try{
    await fetch('/suggestions',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({title:t,rule:r,language:document.getElementById('sug-lang').value,team:team,example_bad:document.getElementById('sug-bad').value,example_good:document.getElementById('sug-good').value})});
    document.getElementById('sug-title').value='';document.getElementById('sug-rule').value='';loadRules();
  }catch(e){alert(e.message)}
}
async function deleteRule(id){try{await fetch('/suggestions/'+id,{method:'DELETE'});loadRules()}catch(e){alert(e.message)}}
function esc(s){if(s===null||s===undefined)return'';const d=document.createElement('div');d.textContent=String(s);return d.innerHTML}
</script>
</body>
</html>
